# name: test/sql/hortus_pipeline.test
# description: test hortus_pipeline extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require hortus_pipeline

# Confirm the extension loads successfully
query I
SELECT 1;
----
1

# Test that our custom SQL statements are parsed and routed
query I
CREATE OR REFRESH MATERIALIZED VIEW test_view AS SELECT 1 AS val;
----
Materialized view 'test_view' created successfully

query I
SELECT val FROM test_view;
----
1

query I
REFRESH ALL MATERIALIZED VIEWS;
----
All materialized views refreshed successfully
